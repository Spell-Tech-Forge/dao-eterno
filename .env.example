# Dao Eterno — Variáveis de ambiente para Docker Compose
# Copie este arquivo para .env e preencha os valores reais

# Senha do PostgreSQL (use algo forte em produção)
POSTGRES_PASSWORD=mude_esta_senha_em_producao

# Segredo JWT — use uma string longa e aleatória (mínimo 32 chars)
# Gerar: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_SECRET=mude_este_segredo_em_producao_com_string_longa_e_aleatoria

# Porta externa (default 3001)
PORT=3001
